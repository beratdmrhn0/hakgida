# Hakgida Backend Environment Variables

# Server Configuration
NODE_ENV=production
PORT=3001

# Database Configuration (Railway will auto-provide these)
DATABASE_URL=postgresql://username:password@host:port/database
DATABASE_PRIVATE_URL=postgresql://username:password@private-host:port/database

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=24h

# Admin Configuration
ADMIN_PASSWORD=hakgida2024

# CORS Configuration
FRONTEND_URL=https://hakgida.com
ADMIN_URL=https://hakgida.com/admin.html

# Upload Configuration
UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,gif,webp

# Security
SESSION_SECRET=your-session-secret-here
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Production Settings
TRUST_PROXY=true
ENABLE_COMPRESSION=true
ENABLE_HELMET=true 